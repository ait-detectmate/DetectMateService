        {
            "datasource": {
                "type": "prometheus",
                "uid": "PBFA97CFB590B2093"
            },
            "description": "Tracks how long a single call to process() takes across the parser and detector services, shown at three percentiles. p50 is the typical processing time, half of all messages are faster than this. p95 means 95% of messages complete within this time, with the slowest 5% taking longer. p99: only 1% of messages take longer than this.\n\nA healthy pipeline shows all three lines low, stable, and close together. If p99 starts climbing while p50 stays flat, it means most messages process fine but occasional ones are slow. If all three rise together the component is consistently overloaded and cannot keep up with the incoming message rate, which will eventually cause backpressure and dropped messages upstream.",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "axisBorderShow": false,
                        "axisCenteredZero": false,
                        "axisColorMode": "text",
